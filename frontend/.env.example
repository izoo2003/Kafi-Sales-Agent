# Local: leave API base relative so Vite proxies /api → backend (same-origin cookies).
VITE_BACKEND_URL=http://127.0.0.1:8001
# Prefer unset or /api (same-origin). Do NOT point at absolute Railway URL on Vercel —
# vercel.json rewrites /api → Railway so httpOnly cookies stay on your Vercel domain.
# VITE_API_BASE_URL=/api

# Optional external quotation agent
# VITE_QUOTATION_AGENT_URL=https://bank-recon-demo.vercel.app/cnf
