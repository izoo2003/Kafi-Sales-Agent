# Database — Supabase (recommended)
# 1. Supabase dashboard → Project Settings → Database → Connection string → URI
# 2. Choose "Direct connection" (port 5432) for local dev + Alembic migrations
# 3. Replace [YOUR-PASSWORD] with your database password
# 4. Keep sslmode=require at the end
#
# Example:
# DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
#
# Local Postgres (alternative):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kafi_sales_agent

# API
API_HOST=0.0.0.0
API_PORT=8001
API_DEBUG=true

# CORS (comma-separated origins — production Vercel URL included by default)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://kafi-sales-agent.vercel.app

# Gemini LLM — website summaries, lead scoring reasoning, email drafts (modules/llm_client.py)
# GEMINI_API_KEY=          # https://aistudio.google.com/apikey
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-3.5-flash,gemini-2.0-flash
# GEMINI_MAX_OUTPUT_TOKENS=4096

# Product chatbot — separate keys (modules/product_chatbot.py). Does NOT use GEMINI_API_KEY.
# CHATBOT_GEMINI_API_KEY=
# CHATBOT_GEMINI_API_KEYS=          # optional comma-separated extra Gemini keys
# CHATBOT_GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-3.1-flash-lite,gemini-3.5-flash,gemini-2.0-flash
# CHATBOT_OPENAI_API_KEY=
# CHATBOT_ANTHROPIC_API_KEY=

# KPI Generation summaries — separate key (modules/activity.py). Does NOT use GEMINI_API_KEY.
# KPI_GEMINI_API_KEY=
# KPI_GEMINI_API_KEYS=              # optional comma-separated extra Gemini keys
# KPI_GEMINI_MODEL=gemini-3.1-flash-lite
# KPI_GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-3.5-flash,gemini-2.0-flash
# KPI_GEMINI_MAX_OUTPUT_TOKENS=1024

# Email / Inbox — company mailbox, two supported modes:
#
# 1) cPanel / standard SMTP+IMAP mail (e.g. mail.kafi-group.com) — recommended, simplest.
#    Get IMAP/SMTP host+ports from your cPanel "Mail Client Manual Settings" page
#    (webmail login e.g. https://your-domain.com:2096/).
#
# MAILBOX_ENABLED=true
# MAILBOX_EMAIL=test@kafi-group.com
# MAILBOX_PASSWORD=                 # the mailbox's own password (cPanel email account password)
# MAILBOX_DISPLAY_NAME=Kafi Commodities
# MAILBOX_IMAP_HOST=67.23.252.42        # use direct IP if Cloudflare proxies the hostname
# MAILBOX_IMAP_PORT=993             # IMAP SSL
# MAILBOX_SMTP_HOST=67.23.252.42
# MAILBOX_SMTP_PORT=465             # SMTP SSL (implicit TLS)
# MAILBOX_SSL_HOSTNAME=mail.kafi-group.com  # cert hostname when hosts are a raw IP
#
# 2) Outlook.com via OAuth (IMAP receive + Microsoft Graph Mail.Send) — used only when
#    MAILBOX_CLIENT_ID + MAILBOX_REFRESH_TOKEN are set below (personal @outlook.com often
#    has SMTP AUTH disabled — 5.7.139 — so this mode bypasses SMTP entirely via Graph).
#    Setup: python scripts/get_outlook_refresh_token.py
#    Azure: Microsoft Graph → Delegated → Mail.Send (+ IMAP consent via the script)
#
# MAILBOX_CLIENT_ID=
# MAILBOX_CLIENT_SECRET=          # optional for public/desktop apps
# MAILBOX_REFRESH_TOKEN=
# MAILBOX_TENANT_ID=consumers       # use your Azure tenant id for work/school accounts
#
# INBOX_SINCE=2026-07-08            # optional — only show mail from this date/time onward
#
# Email open tracking (Insights) — public API URL used in tracking pixels
# PUBLIC_API_BASE_URL=https://kafi-sales-agent-production.up.railway.app
# EMAIL_TRACK_SECRET=               # optional; defaults to mailbox password
# Lead discovery / Research & Score enrichment (see modules/web_search.py + company_enrichment.py)
# Default combined providers: serpapi,duckduckgo,google_cse,wikidata
# CompanyLens runs after a website/domain is found (fills socials + contacts).
#
WEB_SEARCH_COMBINED_PROVIDERS=serpapi,duckduckgo,google_cse
WEB_SEARCH_PROVIDERS=serpapi,duckduckgo,google_cse,wikidata
# SERPAPI_API_KEY=                    # primary key
# SERPAPI_API_KEYS=key2,key3          # optional extras — auto-rotates on 429/quota
# GOOGLE_CSE_API_KEY=                 # https://developers.google.com/custom-search/v1/overview
# GOOGLE_CSE_ENGINE_ID=               # Programmable Search Engine cx id
# COMPANYLENS_API_KEY=                # https://companylens.dev/ — 500 free lookups/mo
# Wikidata SPARQL needs no API key.

# WhatsApp Cloud API (Meta) — integrations/whatsapp_client.py
# Setup:
# 1. Meta Business Manager (business.facebook.com) → create a business, then a WhatsApp
#    Business Account (WABA) and register/verify a sending phone number.
# 2. developers.facebook.com → your app → add the WhatsApp product.
#    Copy the Phone Number ID and WhatsApp Business Account ID shown there.
# 3. Business Settings → System Users → create one, assign the WABA, generate a
#    permanent token with whatsapp_business_messaging + whatsapp_business_management
#    → WHATSAPP_ACCESS_TOKEN (avoids the 24h temporary token).
# 4. Business Settings → Accounts → Apps → App secret → WHATSAPP_APP_SECRET
#    (used to verify inbound webhook signatures).
# 5. Choose your own random string for WHATSAPP_WEBHOOK_VERIFY_TOKEN, then in the
#    app's WhatsApp → Configuration → Webhook, enter:
#      Callback URL: https://YOUR-PUBLIC-API/api/webhooks/whatsapp
#      Verify token: (same string)
#    Subscribe to the "messages" webhook field. Local dev: ngrok http 8001.
# 6. Create message templates in Business Manager (marketing + utility) and wait for
#    Meta approval, then sync them via POST /api/whatsapp/templates/sync.
#
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_APP_SECRET=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=choose-a-random-string
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_VALIDATE_WEBHOOKS=true
# BULK_WHATSAPP_MESSAGE_DELAY_SECONDS=2.0
# BULK_WHATSAPP_MAX_PER_REQUEST=250

# Twilio Voice — browser calling from dashboard (integrations/voice_client.py)
# Flow: click Call in dashboard → talk via browser mic → client is dialed directly.
#
# Setup:
# 1. Twilio Console → Account SID + Primary Auth Token
# 2. Buy a Voice-capable phone number → TWILIO_PHONE_NUMBER
# 3. Console → Account → API keys & tokens → Create API Key
#    → TWILIO_API_KEY_SID + TWILIO_API_KEY_SECRET
# 4. Console → Voice → TwiML → TwiML Apps → Create new App
#    Voice Request URL (POST):
#    https://YOUR-PUBLIC-API/api/webhooks/twilio/voice/client-dial
#    → copy App SID to TWILIO_TWIML_APP_SID
# 5. Local dev: ngrok http 8001 → TWILIO_WEBHOOK_BASE_URL=https://abc.ngrok-free.app
# 6. Restart backend
#
# Calls are recorded automatically (Twilio Dial recording). After the call ends,
# the recording is saved and closed captions (speech-to-text) are generated with
# Gemini when GEMINI_API_KEY is set.
#
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=your_primary_auth_token
# TWILIO_PHONE_NUMBER=+1234567890
# TWILIO_API_KEY_SID=SKxxxxxxxx
# TWILIO_API_KEY_SECRET=your_api_key_secret
# TWILIO_TWIML_APP_SID=APxxxxxxxx
# TWILIO_WEBHOOK_BASE_URL=https://abc123.ngrok-free.app
# TWILIO_VALIDATE_WEBHOOKS=true

# Meta Graph API (configure when ready)
# META_ACCESS_TOKEN=
# META_PAGE_ID=
