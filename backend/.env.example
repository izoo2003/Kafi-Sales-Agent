# Database — Supabase (recommended)
# 1. Supabase dashboard → Project Settings → Database → Connection string → URI
# 2. Choose "Direct connection" (port 5432) for local dev + Alembic migrations
# 3. Replace [YOUR-PASSWORD] with your database password
# 4. Keep sslmode=require at the end
#
# Example:
# DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
#
# Local Postgres (alternative):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kafi_sales_agent

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# CORS (comma-separated origins — add your Vercel URL in production)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM (not used yet — plug in later)
# LLM_PROVIDER=gemini
# LLM_API_KEY=

# Email (Gmail API — required for Approve & Send)
# Setup (recommended — avoids OAuth Playground redirect_uri_mismatch):
#   1. Google Cloud → enable Gmail API → OAuth consent screen → add test user
#   2. Credentials → Create OAuth client → **Desktop app** → download JSON
#   3. Save JSON as backend/credentials.json (gitignored)
#   4. Run: python scripts/get_gmail_refresh_token.py
#   5. Paste printed values below
#
# OAuth Playground alternative: use **Web application** client (not Desktop) and add
# redirect URI: https://developers.google.com/oauthplayground
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# GMAIL_SENDER_EMAIL=sales@yourcompany.com

# Lead discovery — web search (steps 1–2; see modules/web_search.py)
# Default order: brave first (free tier), then serpapi (paid fallback for knowledge panel).
# WEB_SEARCH_PROVIDERS=brave,serpapi
# BRAVE_API_KEY=          # https://brave.com/search/api/ — free tier ~2 000 queries/month
# SERPAPI_API_KEY=        # https://serpapi.com — paid; used when Brave returns nothing

# WhatsApp Cloud API (configure when ready)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Meta Graph API (configure when ready)
# META_ACCESS_TOKEN=
# META_PAGE_ID=
