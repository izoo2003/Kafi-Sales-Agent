# Database — Supabase (recommended)
# 1. Supabase dashboard → Project Settings → Database → Connection string → URI
# 2. Choose "Direct connection" (port 5432) for local dev + Alembic migrations
# 3. Replace [YOUR-PASSWORD] with your database password
# 4. Keep sslmode=require at the end
#
# Example:
# DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
#
# Local Postgres (alternative):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kafi_sales_agent

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# CORS (comma-separated origins — add your Vercel URL in production)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Gemini LLM — website summaries, lead scoring reasoning, email drafts (modules/llm_client.py)
# GEMINI_API_KEY=          # https://aistudio.google.com/apikey
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-2.5-flash
# GEMINI_MAX_OUTPUT_TOKENS=512

# Email / Inbox (Gmail API) — powers in-app Inbox, replies, and Approve & Send.
# Setup (no Azure needed):
#   1. https://console.cloud.google.com → enable Gmail API
#   2. OAuth consent screen → add your Gmail as a test user
#   3. Credentials → OAuth client → **Desktop app** → download JSON
#   4. Save JSON as backend/credentials.json (gitignored)
#   5. Run: python scripts/get_gmail_refresh_token.py
#   6. Paste printed values below and restart backend
#
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# GMAIL_SENDER_EMAIL=sales@yourcompany.com
# GMAIL_INBOX_SINCE=2026-07-08   # optional — only show mail from this date/time onward

# Lead discovery — web search (see modules/web_search.py)
# WEB_SEARCH_COMBINED_PROVIDERS=serpapi,duckduckgo
# WEB_SEARCH_PROVIDERS=serpapi,duckduckgo
# SERPAPI_API_KEY=

# WhatsApp Cloud API (configure when ready)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Twilio Voice — international outbound calls (integrations/voice_client.py)
# 1. Sign up at https://www.twilio.com/try-twilio
# 2. Console → Account SID + Auth Token
# 3. Buy a number (US/UK recommended for international caller ID)
# 4. For local dev, expose API with ngrok: ngrok http 8000 → set URL below
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1234567890
# TWILIO_AGENT_PHONE=+92xxxxxxxxxx
# TWILIO_WEBHOOK_BASE_URL=https://your-public-api-url

# Meta Graph API (configure when ready)
# META_ACCESS_TOKEN=
# META_PAGE_ID=
